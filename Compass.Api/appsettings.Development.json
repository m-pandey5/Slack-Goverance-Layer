{
  "Slack": {
    "BotToken": "xoxb-YOUR-BOT-TOKEN",
    "SigningSecret": "YOUR-SIGNING-SECRET",
    "AlertsChannel": "#compass-alerts",
    "McpEndpoint": "https://mcp.slack.com/mcp",
    "McpBearerToken": "YOUR-MCP-BEARER-TOKEN",
    "ApiBaseUrl": "https://slack.com/api"
  },
  "Approvals": {
    "FilePath": "data/approvals.json",
    "Channel": "#compass-approvals",
    "PersistAuthorizationHeader": false
  },
  "ProxyTokens": {
    "RedisConnectionString": "",
    "Mappings": {}
  },
  "Agents": {
    "FilePath": "data/agents.json",
    "Seed": [
      {
        "ProxyToken": "compass-ring0-internal-token",
        "AgentId": "did:mesh:compass-internal-svc",
        "Name": "Compass Internal Service",
        "Owner": "platform-team",
        "Ring": 0,
        "TrustScore": 900,
        "AllowedTools": [],
        "BlockedTools": []
      },
      {
        "ProxyToken": "compass-ring2-standard-token",
        "AgentId": "did:mesh:hr-onboarding-agent",
        "Name": "HR Onboarding Agent",
        "Owner": "hr-team",
        "Ring": 2,
        "TrustScore": 500,
        "AllowedTools": ["chat.postMessage", "conversations.list", "users.list", "conversations.invite"],
        "BlockedTools": ["files.delete", "admin.users.invite"]
      },
      {
        "ProxyToken": "compass-ring3-external-token",
        "AgentId": "did:mesh:external-partner-bot",
        "Name": "External Partner Bot",
        "Owner": "partner-org",
        "Ring": 3,
        "TrustScore": 300,
        "AllowedTools": ["chat.postMessage", "conversations.list"],
        "BlockedTools": ["conversations.archive", "files.delete", "admin.users.invite"]
      }
    ]
  },
  "Audit": {
    "FilePath": "data/audit.jsonl"
  },
  "ServiceBus": {
    "ConnectionString": "",
    "ApprovalDecisionsQueue": "compass-approval-decisions"
  },
  "Governance": {
    "PolicyDirectory": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Compass": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  }
